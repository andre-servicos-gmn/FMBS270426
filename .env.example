# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Evolution API
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
# EVOLUTION_WEBHOOK_TOKEN — segredo arbitrário (gere com: openssl rand -hex 32)
# que VALIDA toda chamada de webhook do Evolution. Quando setado, qualquer
# requisição POST /webhook/whatsapp sem header `apikey: <token>` é rejeitada
# com 401. Vazio em dev local mantém o webhook aberto (warning no log).
# CONFIGURAR no Evolution: painel da instância → Settings → Webhook →
# Custom Headers → adicionar { "apikey": "<mesmo-valor-daqui>" }.
EVOLUTION_WEBHOOK_TOKEN=

# Admin
ADMIN_API_KEY=

# RESET_ALLOWED_PHONES — números autorizados a usar o comando `/reset` no WhatsApp.
# Formato: lista separada por vírgula, internacional sem o + (ex:
# "5511987654321,5511912345678"). Vazio → /reset desativado pra TODO mundo
# (recomendado em produção). O dono (Andre) e o piloto (Felipe) são os
# principais entries em dev/staging.
RESET_ALLOWED_PHONES=

# Debounce de mensagens rápidas (Sprint 2.7.2). Mensagens de TEXTO do mesmo
# cliente dentro de MESSAGE_DEBOUNCE_MS são agrupadas e processadas como UMA.
# Resolve a duplicação de resposta quando o cliente manda pensamentos
# fragmentados ("Quero a Proteo" + "Vc tem?" 200ms depois → 1 resposta
# coerente). MESSAGE_DEBOUNCE_CAP e MESSAGE_DEBOUNCE_HARD_TTL_MS são
# circuit-breakers (cap de N msgs força flush; se o cliente fica resetando
# o timer indefinidamente, força flush após hard_ttl). Defaults razoáveis.
MESSAGE_DEBOUNCE_MS=1500
MESSAGE_DEBOUNCE_CAP=10
MESSAGE_DEBOUNCE_HARD_TTL_MS=8000

# Áudio (Sprint 3.10 — guardas de custo do Whisper).
# AUDIO_MAX_SECONDS: áudio acima disso é recusado ANTES do download (lê
#   audioMessage.seconds do payload do Evolution).
# AUDIO_MAX_BYTES: teto pós-download, fallback quando o payload não traz a
#   duração (arquivo encaminhado).
# AUDIO_RATE_LIMIT_PER_HOUR: máx. de áudios por cliente por hora (janela fixa
#   no Redis). 0 desativa o limite.
# AUDIO_TRANSCRIPT_CACHE_TTL: segundos de cache da transcrição por SHA-256 do
#   conteúdo — áudio idêntico reenviado não paga Whisper de novo.
AUDIO_MAX_SECONDS=180
AUDIO_MAX_BYTES=8000000
AUDIO_RATE_LIMIT_PER_HOUR=10
AUDIO_TRANSCRIPT_CACHE_TTL=86400

# Redis  (local em dev, Railway em prod)
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=86400
SESSION_HARD_CAP_SECONDS=604800

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Banco de dados — usar o Transaction Pooler URI (porta 6543), NÃO o Session Mode (5432).
# Encontre em: Supabase Dashboard → Project Settings → Database → Connection String → URI
# Selecione "Transaction" no dropdown antes de copiar o URI.
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:[password]@aws-0-REGION.pooler.supabase.com:6543/postgres

# Catálogo
CATALOG_SOURCE=api
CATALOG_API_URL=
CATALOG_API_KEY=
CATALOG_FILE_PATH=
CATALOG_SYNC_CRON=0 */6 * * *

# Embeddings
EMBEDDING_PROVIDER=voyage
EMBEDDING_API_KEY=

# Compliance
PII_MASK_ENABLED=true
PII_SALT=change-me-in-production
LEAD_RETENTION_DAYS=365

# Dossiê de handoff (Sprint 2.2) — número que recebe o dossiê do cliente no WhatsApp
# quando o agente faz handoff (humano, agendamento, compra, fora de escopo).
# Formato: internacional sem o +  (ex: 5511987654321). Vazio → dossiê só salvo no
# banco, nenhum envio externo (fallback gracioso).
DOSSIER_RECIPIENT_PHONE=

# Loja física (CTA do close_node) — se vazios, o agente cai em fallback genérico
STORE_NAME=
STORE_ADDRESS=
STORE_HOURS=
STORE_MAPS_URL=
STORE_PHONE=

# Bling ERP — OAuth 2.0 (Sprint 2.5)
# Andre cria o app privado em https://www.bling.com.br/Painel.php#tab=apps
# e copia Client ID + Client Secret aqui.
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
BLING_REDIRECT_URI=https://ola-nonauthentic-regenia.ngrok-free.dev/bling/oauth/callback

# Bling sync — categorias relevantes (nomes EXATOS, separados por vírgula).
BLING_SYNC_CATEGORIES=Raquetes de Praia,RAQUETE PADEL,Bola Beach TEnnis,GRIPS,UNDERGRIP,Anti Vibradores,RAQUETEIRAS MOCHILA,Camisetas e Camisas,Shorts,Short,Top,Saias,Camiseta Babylook,Calça Legging,Calças,Vestidos,Sapatilha,Bonés

# Bling sync — agendamento + caches
BLING_SYNC_HOUR=4              # hora UTC do sync diário (4am UTC ≈ 1am Brasília)
BLING_STOCK_CACHE_TTL=300      # segundos (5 min) — TTL do cache de saldo

# Bling webhook — segredo HMAC (gerado quando Andre cadastra o webhook no painel)
BLING_WEBHOOK_SECRET=

# App
APP_ENV=development
LOG_LEVEL=INFO
